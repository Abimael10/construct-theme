  "semanticTokenColors": {
    "enabled": true,
    "variable": "#2f3f58",
    "variable.readonly": "#904d14",
    "variable.defaultLibrary": {
      "foreground": "#904d14"
    },
    "parameter": {
      "foreground": "#934d25",
      "fontStyle": "italic"
    },
    "property": "#297ba0",
    "property.readonly": "#904d14",
    "variable.declaration": "#2f3f58",
    "function": "#17789b",
    "function.defaultLibrary": "#17789b",
    "method": "#17789b",
    "method.defaultLibrary": "#17789b",
    "macro": "#1f7b99",
    "decorator": {
      "foreground": "#1f7b99",
      "fontStyle": "italic"
    },
    "type": "#5821ab",
    "type.defaultLibrary": "#5821ab",
    "class": "#5821ab",
    "class.defaultLibrary": "#5821ab",
    "interface": "#5821ab",
    "enum": "#5821ab",
    "enumMember": "#904d14",
    "struct": "#5821ab",
    "typeParameter": {
      "foreground": "#5821ab",
      "fontStyle": "italic"
    },
    "namespace": "#5821ab",
    "keyword": "#901462",
    "modifier": "#8c1765",
    "string": "#19854f",
    "number": "#885011",
    "regexp": "#158a6e",
    "operator": "#396b92",
    "variable.label": "#904d14",
    "selfKeyword": {
      "foreground": "#901462",
      "fontStyle": "italic"
    },
    "builtinConstant": "#904d14",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5d6d8c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc keyword",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc"
      ],
      "settings": {
        "foreground": "#5d6d8c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc type",
      "scope": [
        "comment.block.documentation entity.name.type",
        "comment.block.documentation entity.name"
      ],
      "settings": {
        "foreground": "#5821ab",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#2f3f58"
      }
    },
    {
      "name": "Variable: language (this/self/super)",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#901462",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property / member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#297ba0"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#934d25",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#4b82b3"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "storage.type.function.arrow",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#396b92"
      }
    },
    {
      "name": "Punctuation: accessor / delimiter",
      "scope": [
        "punctuation.accessor",
        "meta.delimiter",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#396b92"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#901462",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword: control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#901462",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8c1765"
      }
    },
    {
      "name": "Keyword: operator (word)",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.control.new"
      ],
      "settings": {
        "foreground": "#901462"
      }
    },
    {
      "name": "Modifier",
      "scope": [
        "storage.modifier",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#8c1765"
      }
    },
    {
      "name": "Function: declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#17789b"
      }
    },
    {
      "name": "Function: call",
      "scope": [
        "meta.function-call",
        "variable.function",
        "entity.name.function.call"
      ],
      "settings": {
        "foreground": "#17789b"
      }
    },
    {
      "name": "Support function (built-in)",
      "scope": [
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#17789b"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#1f7b99",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "meta.type.annotation",
        "support.class"
      ],
      "settings": {
        "foreground": "#5821ab"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#5821ab"
      }
    },
    {
      "name": "Interface / enum / struct",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#5821ab"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.namespace"
      ],
      "settings": {
        "foreground": "#5821ab"
      }
    },
