  "semanticTokenColors": {
    "enabled": true,
    "variable": "#bbc5d8",
    "variable.readonly": "#eaa971",
    "variable.defaultLibrary": {
      "foreground": "#eaa971"
    },
    "parameter": {
      "foreground": "#e1ad8e",
      "fontStyle": "italic"
    },
    "property": "#97cbe3",
    "property.readonly": "#eaa971",
    "variable.declaration": "#bbc5d8",
    "function": "#80ceea",
    "function.defaultLibrary": "#80ceea",
    "method": "#80ceea",
    "method.defaultLibrary": "#80ceea",
    "macro": "#82cce4",
    "decorator": {
      "foreground": "#82cce4",
      "fontStyle": "italic"
    },
    "type": "#ba99ea",
    "type.defaultLibrary": "#ba99ea",
    "class": "#ba99ea",
    "class.defaultLibrary": "#ba99ea",
    "interface": "#ba99ea",
    "enum": "#ba99ea",
    "enumMember": "#eaa971",
    "struct": "#ba99ea",
    "typeParameter": {
      "foreground": "#ba99ea",
      "fontStyle": "italic"
    },
    "namespace": "#ba99ea",
    "keyword": "#ea71be",
    "modifier": "#e774c0",
    "string": "#73e2ab",
    "number": "#eaad66",
    "regexp": "#6ee7cb",
    "operator": "#83a7cb",
    "variable.label": "#eaa971",
    "selfKeyword": {
      "foreground": "#ea71be",
      "fontStyle": "italic"
    },
    "builtinConstant": "#eaa971",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#727b9b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc keyword",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc"
      ],
      "settings": {
        "foreground": "#727b9b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc type",
      "scope": [
        "comment.block.documentation entity.name.type",
        "comment.block.documentation entity.name"
      ],
      "settings": {
        "foreground": "#ba99ea",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#bbc5d8"
      }
    },
    {
      "name": "Variable: language (this/self/super)",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#ea71be",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property / member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#97cbe3"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#e1ad8e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#507eb1"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "storage.type.function.arrow",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#83a7cb"
      }
    },
    {
      "name": "Punctuation: accessor / delimiter",
      "scope": [
        "punctuation.accessor",
        "meta.delimiter",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#83a7cb"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#ea71be",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword: control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#ea71be",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e774c0"
      }
    },
    {
      "name": "Keyword: operator (word)",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.control.new"
      ],
      "settings": {
        "foreground": "#ea71be"
      }
    },
    {
      "name": "Modifier",
      "scope": [
        "storage.modifier",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#e774c0"
      }
    },
    {
      "name": "Function: declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#80ceea"
      }
    },
    {
      "name": "Function: call",
      "scope": [
        "meta.function-call",
        "variable.function",
        "entity.name.function.call"
      ],
      "settings": {
        "foreground": "#80ceea"
      }
    },
    {
      "name": "Support function (built-in)",
      "scope": [
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#80ceea"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#82cce4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "meta.type.annotation",
        "support.class"
      ],
      "settings": {
        "foreground": "#ba99ea"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#ba99ea"
      }
    },
    {
      "name": "Interface / enum / struct",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#ba99ea"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.namespace"
      ],
      "settings": {
        "foreground": "#ba99ea"
      }
    },
    {
      "name": "Type: primitive / builtin",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#ba99ea"
      }
    },
    {
      "name": "Generic / type parameter",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters"
