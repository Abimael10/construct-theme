  "semanticTokenColors": {
    "enabled": true,
    "variable": "#bec7d5",
    "variable.readonly": "#e5af80",
    "variable.defaultLibrary": {
      "foreground": "#e5af80"
    },
    "parameter": {
      "foreground": "#deb49c",
      "fontStyle": "italic"
    },
    "property": "#a5cee0",
    "property.readonly": "#e5af80",
    "variable.declaration": "#bec7d5",
    "function": "#8ecfe6",
    "function.defaultLibrary": "#8ecfe6",
    "method": "#8ecfe6",
    "method.defaultLibrary": "#8ecfe6",
    "macro": "#92cde0",
    "decorator": {
      "foreground": "#92cde0",
      "fontStyle": "italic"
    },
    "type": "#c0a6e7",
    "type.defaultLibrary": "#c0a6e7",
    "class": "#c0a6e7",
    "class.defaultLibrary": "#c0a6e7",
    "interface": "#c0a6e7",
    "enum": "#c0a6e7",
    "enumMember": "#e5af80",
    "struct": "#c0a6e7",
    "typeParameter": {
      "foreground": "#c0a6e7",
      "fontStyle": "italic"
    },
    "namespace": "#c0a6e7",
    "keyword": "#e580c0",
    "modifier": "#e283c2",
    "string": "#82deb0",
    "number": "#e5b176",
    "regexp": "#7de3cb",
    "operator": "#93b1ca",
    "variable.label": "#e5af80",
    "selfKeyword": {
      "foreground": "#e580c0",
      "fontStyle": "italic"
    },
    "builtinConstant": "#e5af80",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#828ba0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc keyword",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc"
      ],
      "settings": {
        "foreground": "#828ba0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc type",
      "scope": [
        "comment.block.documentation entity.name.type",
        "comment.block.documentation entity.name"
      ],
      "settings": {
        "foreground": "#c0a6e7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#bec7d5"
      }
    },
    {
      "name": "Variable: language (this/self/super)",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#e580c0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property / member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#a5cee0"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#deb49c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#6a8fb2"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "storage.type.function.arrow",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#93b1ca"
      }
    },
    {
      "name": "Punctuation: accessor / delimiter",
      "scope": [
        "punctuation.accessor",
        "meta.delimiter",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#93b1ca"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#e580c0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword: control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#e580c0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e283c2"
      }
    },
    {
      "name": "Keyword: operator (word)",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.control.new"
      ],
      "settings": {
        "foreground": "#e580c0"
      }
    },
    {
      "name": "Modifier",
      "scope": [
        "storage.modifier",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#e283c2"
      }
    },
    {
      "name": "Function: declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#8ecfe6"
      }
    },
    {
      "name": "Function: call",
      "scope": [
        "meta.function-call",
        "variable.function",
        "entity.name.function.call"
      ],
      "settings": {
        "foreground": "#8ecfe6"
      }
    },
    {
      "name": "Support function (built-in)",
      "scope": [
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#8ecfe6"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#92cde0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "meta.type.annotation",
        "support.class"
      ],
      "settings": {
        "foreground": "#c0a6e7"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#c0a6e7"
      }
    },
    {
      "name": "Interface / enum / struct",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#c0a6e7"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.namespace"
      ],
      "settings": {
        "foreground": "#c0a6e7"
      }
    },
    {
      "name": "Type: primitive / builtin",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
