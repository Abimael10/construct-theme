  "semanticTokenColors": {
    "enabled": true,
    "variable": "#c2c1d9",
    "variable.readonly": "#e9ac77",
    "variable.defaultLibrary": {
      "foreground": "#e9ac77"
    },
    "parameter": {
      "foreground": "#e1b094",
      "fontStyle": "italic"
    },
    "property": "#9dbde2",
    "property.readonly": "#e9ac77",
    "variable.declaration": "#c2c1d9",
    "function": "#86cfea",
    "function.defaultLibrary": "#86cfea",
    "method": "#86cfea",
    "method.defaultLibrary": "#86cfea",
    "macro": "#89afe3",
    "decorator": {
      "foreground": "#89afe3",
      "fontStyle": "italic"
    },
    "type": "#bd9fea",
    "type.defaultLibrary": "#bd9fea",
    "class": "#bd9fea",
    "class.defaultLibrary": "#bd9fea",
    "interface": "#bd9fea",
    "enum": "#bd9fea",
    "enumMember": "#e9ac77",
    "struct": "#bd9fea",
    "typeParameter": {
      "foreground": "#bd9fea",
      "fontStyle": "italic"
    },
    "namespace": "#bd9fea",
    "keyword": "#e977c7",
    "modifier": "#e67ac2",
    "string": "#79e2ad",
    "number": "#e9af6d",
    "regexp": "#74e7cc",
    "operator": "#aa8cc9",
    "variable.label": "#e9ac77",
    "selfKeyword": {
      "foreground": "#e977c7",
      "fontStyle": "italic"
    },
    "builtinConstant": "#e9ac77",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#777d9b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc keyword",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc"
      ],
      "settings": {
        "foreground": "#777d9b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment: doc type",
      "scope": [
        "comment.block.documentation entity.name.type",
        "comment.block.documentation entity.name"
      ],
      "settings": {
        "foreground": "#bd9fea",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#c2c1d9"
      }
    },
    {
      "name": "Variable: language (this/self/super)",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#e977c7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property / member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#9dbde2"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#e1b094",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#7e5dae"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "storage.type.function.arrow",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#aa8cc9"
      }
    },
    {
      "name": "Punctuation: accessor / delimiter",
      "scope": [
        "punctuation.accessor",
        "meta.delimiter",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#aa8cc9"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#e977c7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword: control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#e977c7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e67ac2"
      }
    },
    {
      "name": "Keyword: operator (word)",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.control.new"
      ],
      "settings": {
        "foreground": "#e977c7"
      }
    },
    {
      "name": "Modifier",
      "scope": [
        "storage.modifier",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#e67ac2"
      }
    },
    {
      "name": "Function: declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#86cfea"
      }
    },
    {
      "name": "Function: call",
      "scope": [
        "meta.function-call",
        "variable.function",
        "entity.name.function.call"
      ],
      "settings": {
        "foreground": "#86cfea"
      }
    },
    {
      "name": "Support function (built-in)",
      "scope": [
        "support.function",
        "support.macro"
      ],
      "settings": {
        "foreground": "#86cfea"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#89afe3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "meta.type.annotation",
        "support.class"
      ],
      "settings": {
        "foreground": "#bd9fea"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#bd9fea"
      }
    },
    {
      "name": "Interface / enum / struct",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#bd9fea"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.namespace"
      ],
      "settings": {
        "foreground": "#bd9fea"
      }
    },
    {
      "name": "Type: primitive / builtin",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#bd9fea"
      }
    },
    {
